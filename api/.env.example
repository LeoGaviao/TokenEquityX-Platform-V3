# ─── SERVER ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tokenequityx_v2

# ─── AUTHENTICATION ───────────────────────────────────────────────
# REQUIRED — server will refuse to start if this is not set
# Generate with: openssl rand -hex 64
# Never use a short or guessable value in production
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_EXPIRES_IN=24h

# ─── BLOCKCHAIN ───────────────────────────────────────────────────
# Local Hardhat node (default for development)
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=1337

# ── Polygon PoS Mainnet (PRODUCTION — chainId 137) ────────────────
# Uncomment these and comment out the local values above when deploying to production.
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# CHAIN_ID=137

# Deployer wallet private key — needed for on-chain KYC approval and oracle price updates
# Local dev: use Hardhat account #0 (safe — it's a well-known test key)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Production: set this in Render as a secret env var — NEVER commit the real key
# DEPLOYER_PRIVATE_KEY=0xYOUR_REAL_PRIVATE_KEY

# Polygonscan API key (for contract verification)
# https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Founder wallet addresses (used by PlatformAdmin contract)
FOUNDER_1_ADDRESS=0xce1EBe789E0067F08222e5cD0456a02C7a7c8E90
FOUNDER_2_ADDRESS=0x0Ba9A1e6bD3785d37E0D5b7d66c01313E7CC6C1c

# Treasury addresses (used by FeeManager)
SECZ_TREASURY_ADDRESS=0x95A6F1E8E066800A4fA79990b658a90163448f5d
PLATFORM_TREASURY_ADDRESS=0x95A6F1E8E066800A4fA79990b658a90163448f5d

# ─── CONTRACT ADDRESSES (Polygon PoS Mainnet — chainId 137) ───────
# Deployed 2026-06-14. Full manifest: contracts/deployed_addresses_mainnet.json
# The API reads these from api/src/blockchain/contract_addresses.json (committed).
# These env vars are provided here as a reference and Render override fallback.
COMPLIANCE_REGISTRY_ADDRESS=0x63e9B40D1e0dA7946039DC7D8B5ca60cfdA0AD9c
KYC_MANAGER_ADDRESS=0xd884dA2d04Bb3F5736dd0b86E4077361AE29ab76
SPV_REGISTRY_ADDRESS=0x4257FD7D14b2DA4561cCd1b5349ED28cc6b041dd
VALUATION_ORACLE_ADDRESS=0x7b487A90a7cfBF3bb06ad5c71f1FAB54eA12112e
FEE_MANAGER_ADDRESS=0x4D297DB29a25651048601e9df2B8Cab8e45348E1
TRADE_ENGINE_ADDRESS=0x5980e46570AcC1f795C7240f23ab41F98f34E215
DISTRIBUTION_MANAGER_ADDRESS=0x6E4236824c15dbea77485d6924f788231a400852
GOVERNANCE_CONTRACT_ADDRESS=0x10fCF90241035F059bE4b78d068CcaDf40282BFC
AUDIT_LOG_ADDRESS=0x349BA6097BCc5D8c76490d99A3840d730aEb978C
ASSET_TOKEN_IMPL_ADDRESS=0xbc2139f07D7D677fdC10474d335d8870B8725907
PLATFORM_ADMIN_ADDRESS=0xa5Dd151bb1E5794C6f3F0811cb237973257079a0

# ─── FILE UPLOADS ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# ─── PLATFORM SETTINGS ────────────────────────────────────────────
PLATFORM_FEE_BPS=50
MAX_KYC_EXPIRY_DAYS=365
DEFAULT_DAILY_TRADE_LIMIT_USD=50000

# ─── RECONCILIATION NOTIFICATIONS (REQUIRED for fix operations) ───
# Both PRIMARY and SECONDARY must be valid for the fix tool to operate.
# Can also be set at runtime via admin dashboard → Reconciliation Settings.
RECONCILIATION_EMAIL_PRIMARY=leomgaviao@tokenequityx.co.zw
RECONCILIATION_EMAIL_SECONDARY=richardchimuka@tokenequityx.co.zw
RECONCILIATION_EMAIL_TERTIARY=          # Optional third recipient

# ─── EMAIL (Resend — active email provider) ───────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=admin@tokenequityx.co.zw
PLATFORM_URL=https://tokenequityx.co.zw
SMTP_FROM=noreply@tokenequityx.co.zw

# ─── SUPABASE STORAGE ─────────────────────────────────────────────
# Project settings at: https://supabase.com/dashboard/project/<ref>/settings/api
# REQUIRED — server will refuse to start without SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── SETUP SECRET (local dev only) ───────────────────────────────
# Only needed if temporarily re-enabling /api/setup routes locally.
# NEVER set this in production — setup routes are not mounted in production.
# SETUP_SECRET=local-dev-only-never-in-production