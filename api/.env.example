# ─── SERVER ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tokenequityx_v2

# ─── AUTHENTICATION ───────────────────────────────────────────────
# REQUIRED — server will refuse to start if this is not set
# Generate with: openssl rand -hex 64
# Never use a short or guessable value in production
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_EXPIRES_IN=24h

# ─── BLOCKCHAIN ───────────────────────────────────────────────────
# Local Hardhat node (default for development)
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=1337

# Polygon Amoy testnet (chain 80002 — replaces deprecated Mumbai 80001)
# Get testnet POL: https://faucet.polygon.technology/ (select Amoy)
# RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# CHAIN_ID=80002
# POLYGON_TESTNET_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon Mainnet
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# CHAIN_ID=137
# POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet private key
# Local dev: use Hardhat account #0 (safe — it's a well-known test key)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Testnet/mainnet: use your actual deployer wallet (NEVER commit this value)
# DEPLOYER_PRIVATE_KEY=0xYOUR_REAL_PRIVATE_KEY

# Polygonscan API key (for contract verification after deployment)
# https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Founder wallet addresses (used by PlatformAdmin contract)
FOUNDER_1_ADDRESS=
FOUNDER_2_ADDRESS=

# Treasury addresses (used by FeeManager — defaults to deployer if empty)
SECZ_TREASURY_ADDRESS=
PLATFORM_TREASURY_ADDRESS=

# ─── CONTRACT ADDRESSES ───────────────────────────────────────────
# Populated automatically by deploy scripts into api/src/blockchain/contract_addresses.json
# Copy values here after running: npx hardhat run scripts/deploy-mumbai.js --network polygon_testnet
COMPLIANCE_REGISTRY_ADDRESS=
KYC_MANAGER_ADDRESS=
SPV_REGISTRY_ADDRESS=
VALUATION_ORACLE_ADDRESS=
FEE_MANAGER_ADDRESS=
TRADE_ENGINE_ADDRESS=
DISTRIBUTION_MANAGER_ADDRESS=
GOVERNANCE_CONTRACT_ADDRESS=
AUDIT_LOG_ADDRESS=
ASSET_TOKEN_IMPL_ADDRESS=
PLATFORM_ADMIN_ADDRESS=

# ─── FILE UPLOADS ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# ─── PLATFORM SETTINGS ────────────────────────────────────────────
PLATFORM_FEE_BPS=50
MAX_KYC_EXPIRY_DAYS=365
DEFAULT_DAILY_TRADE_LIMIT_USD=50000

# ─── RECONCILIATION NOTIFICATIONS (REQUIRED for fix operations) ───
# Both PRIMARY and SECONDARY must be valid for the fix tool to operate.
# Can also be set at runtime via admin dashboard → Reconciliation Settings.
RECONCILIATION_EMAIL_PRIMARY=leomgaviao@tokenequityx.co.zw
RECONCILIATION_EMAIL_SECONDARY=richardchimuka@tokenequityx.co.zw
RECONCILIATION_EMAIL_TERTIARY=          # Optional third recipient

# ─── EMAIL (Resend — active email provider) ───────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=admin@tokenequityx.co.zw
PLATFORM_URL=https://tokenequityx.co.zw
SMTP_FROM=noreply@tokenequityx.co.zw

# ─── SUPABASE STORAGE ─────────────────────────────────────────────
# Project settings at: https://supabase.com/dashboard/project/<ref>/settings/api
# REQUIRED — server will refuse to start without SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── SETUP SECRET (local dev only) ───────────────────────────────
# Only needed if temporarily re-enabling /api/setup routes locally.
# NEVER set this in production — setup routes are not mounted in production.
# SETUP_SECRET=local-dev-only-never-in-production