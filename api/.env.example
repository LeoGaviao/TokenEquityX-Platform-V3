# ─── SERVER ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tokenequityx_v2

# ─── AUTHENTICATION ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# ─── BLOCKCHAIN ───────────────────────────────────────────────────
# Local Hardhat node
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=1337

# Polygon Amoy testnet (for testnet deployment)
# RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY_HERE
# CHAIN_ID=80002

# Platform deployer wallet (from Hardhat account #0)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── CONTRACT ADDRESSES ───────────────────────────────────────────
# Fill these in after running: npx hardhat run scripts/deploy.js
USDC_ADDRESS=
COMPLIANCE_ADDRESS=
ORACLE_ADDRESS=
FACTORY_ADDRESS=
GOVERNANCE_ADDRESS=
DIVIDEND_ADDRESS=
DEBT_ADDRESS=
MARKET_CONTROLLER_ADDRESS=
SETTLEMENT_ADDRESS=
P2P_ADDRESS=

# ─── FILE UPLOADS ─────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# ─── PLATFORM SETTINGS ────────────────────────────────────────────
PLATFORM_FEE_BPS=50
MAX_KYC_EXPIRY_DAYS=365
DEFAULT_DAILY_TRADE_LIMIT_USD=50000