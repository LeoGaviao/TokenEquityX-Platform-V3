# ─── API ENDPOINT ─────────────────────────────────────────────────
# Set this in Vercel environment variables for production.
# Must NOT include a trailing slash.
NEXT_PUBLIC_API_URL=https://tokenequityx-api-ljb0.onrender.com/api

# ─── WEBSOCKET ENDPOINT ───────────────────────────────────────────
# Used by investor dashboards for live price feeds.
# Should point to the same host as the API, without /api suffix.
NEXT_PUBLIC_WS_URL=wss://tokenequityx-api-ljb0.onrender.com

# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────
# Uncomment these and comment out the production values above when running locally.
# NEXT_PUBLIC_API_URL=http://localhost:3001/api
# NEXT_PUBLIC_WS_URL=ws://localhost:3001
