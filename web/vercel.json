{
  "version": 2,
  "name": "tokenequityx-web",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "tokenequityx-api-ljb0.onrender.com/api",
    "NEXT_PUBLIC_WS_URL": "wss://tokenequityx-api-ljb0.onrender.com"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://tokenequityx-api-ljb0.onrender.com/api",
      "NEXT_PUBLIC_WS_URL": "wss://tokenequityx-api-ljb0.onrender.com"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
