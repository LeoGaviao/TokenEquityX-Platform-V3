version: '3.8'

# ═══════════════════════════════════════════════════════════════
# TokenEquityX Platform V3 — Docker Compose
# Usage: docker-compose up --build
# ═══════════════════════════════════════════════════════════════

services:

  # ─── MySQL Database ──────────────────────────────────────────
  db:
    image: mysql:8.0
    container_name: tx_database
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD:-tokenequityx_root}
      MYSQL_DATABASE: ${DB_NAME:-tokenequityx_v3}
      MYSQL_USER: ${DB_USER:-txuser}
      MYSQL_PASSWORD: ${DB_PASSWORD:-txpassword}
    ports:
      - "${DB_EXTERNAL_PORT:-3306}:3306"
    volumes:
      - db_data:/var/lib/mysql
      - ./api/src/db/schema.sql:/docker-entrypoint-initdb.d/01-schema.sql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p${DB_ROOT_PASSWORD:-tokenequityx_root}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    networks:
      - tx_network

  # ─── Hardhat Blockchain Node ──────────────────────────────────
  hardhat:
    build:
      context: ./contracts
      dockerfile: Dockerfile.hardhat
    container_name: tx_blockchain
    restart: unless-stopped
    ports:
      - "${HARDHAT_PORT:-8545}:8545"
    networks:
      - tx_network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8545"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ─── Backend API ─────────────────────────────────────────────
  api:
    build:
      context: ./api
      dockerfile: Dockerfile
    container_name: tx_api
    restart: unless-stopped
    ports:
      - "${API_PORT:-3001}:3001"
    environment:
      NODE_ENV: ${NODE_ENV:-production}
      PORT: 3001
      DB_HOST: db
      DB_USER: ${DB_USER:-txuser}
      DB_PASSWORD: ${DB_PASSWORD:-txpassword}
      DB_NAME: ${DB_NAME:-tokenequityx_v3}
      JWT_SECRET: ${JWT_SECRET:-change-this-secret}
      JWT_EXPIRES_IN: ${JWT_EXPIRES_IN:-24h}
      FRONTEND_URL: ${FRONTEND_URL:-http://localhost:3000}
      RPC_URL: http://hardhat:8545
      CHAIN_ID: ${CHAIN_ID:-1337}
      PLATFORM_FEE_BPS: ${PLATFORM_FEE_BPS:-50}
      SETUP_COMPLETE: ${SETUP_COMPLETE:-false}
      SETUP_SECRET: ${SETUP_SECRET:-setup-secret}
    depends_on:
      db:
        condition: service_healthy
      hardhat:
        condition: service_healthy
    volumes:
      - ./uploads:/app/uploads
      - ./logs:/app/logs
    networks:
      - tx_network

  # ─── Frontend ────────────────────────────────────────────────
  web:
    build:
      context: ./web
      dockerfile: Dockerfile
    container_name: tx_web
    restart: unless-stopped
    ports:
      - "${WEB_PORT:-3000}:3000"
    environment:
      NEXT_PUBLIC_API_URL: ${NEXT_PUBLIC_API_URL:-http://localhost:3001/api}
      NEXT_PUBLIC_WS_URL: ${NEXT_PUBLIC_WS_URL:-ws://localhost:3001}
      NEXT_PUBLIC_PLATFORM_NAME: ${PLATFORM_NAME:-TokenEquityX}
    depends_on:
      - api
    networks:
      - tx_network

networks:
  tx_network:
    driver: bridge

volumes:
  db_data:
    driver: local